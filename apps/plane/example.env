AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
BUCKET_NAME=uploads

FILE_SIZE_LIMIT=26214400
GUNICORN_WORKERS=2
SSL_VERIFY=1
