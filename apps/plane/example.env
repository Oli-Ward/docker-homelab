# Copy to apps/plane/.env in Komodo and replace all secret values there.
# Do not commit the real .env file.

APPDATA_ROOT=/srv/appdata

DOMAIN_NAME=plane.home.lab
APP_RELEASE_VERSION=v2.6.3
IS_AIRGAPPED=0

WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
BEAT_WORKER_REPLICAS=1
LIVE_REPLICAS=1
SILO_REPLICAS=1
EMAIL_REPLICAS=0
OUTBOX_POLLER_REPLICAS=1
AUTOMATION_CONSUMER_REPLICAS=1
IFRAMELY_REPLICAS=1
PI_API_REPLICAS=0
PI_BEAT_REPLICAS=0
PI_WORKER_REPLICAS=0
PI_MIGRATOR_REPLICAS=0
MIGRATOR_REPLICAS=0

# Optional services are behind Compose profiles so they do not count as missing
# in the default Komodo deployment.
# Use COMPOSE_PROFILES=migration with MIGRATOR_REPLICAS=1 only during an
# explicit migration maintenance run.
# COMPOSE_PROFILES=pi,email,migration

LISTEN_HTTP_PORT=8085
LISTEN_HTTPS_PORT=8445
LISTEN_SMTP_PORT_25=10025
LISTEN_SMTP_PORT_465=10465
LISTEN_SMTP_PORT_587=10587

TRUSTED_PROXIES=0.0.0.0/0
API_HOSTNAME=http://api:8000
SITE_ADDRESS=http://plane.home.lab:8085
WEB_URL=https://plane.home.lab
CORS_ALLOWED_ORIGINS=https://plane.home.lab
API_BASE_URL=http://api:8000

MACHINE_SIGNATURE=change-me
SECRET_KEY=change-me
AES_SECRET_KEY=change-me
LIVE_SERVER_SECRET_KEY=change-me
SILO_HMAC_SECRET_KEY=change-me
WEBHOOK_SECRET=change-me
PI_INTERNAL_SECRET=change-me

POSTGRES_USER=plane
POSTGRES_PASSWORD=change-me
POSTGRES_DB=plane
PGDATA=/var/lib/postgresql/data
DATABASE_URL=
PLANE_PI_DATABASE_URL=
FOLLOWER_POSTGRES_URI=

REDIS_HOST=plane-redis
